<Window x:Class="MiniPos.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"                
        Title="{Binding Title}" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#F5F6F8">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!--[Row 0, Col 0~1] 상단 헤더 바 -->
        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                Background="#2C3E50" Padding="20,0">
            <TextBlock Text="{Binding Title}"
                       Foreground="White" FontSize="20" FontWeight="Bold"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- [Row 1~2, Col 0] 좌측: 상품 목록 패널 -->
        <Border Grid.Row="1" Grid.RowSpan="2" Grid.Column="0"
                Margin="15" Background="White" CornerRadius="8"
                Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <!-- 영역 타이틀 -->
                <TextBlock Grid.Row="0" Text="📦 상품 선택 (클릭하여 주문)"
                           FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="#34495E"/>
                <!-- 상품 목록을 출력하는 ListBox -->
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Products}"
                         SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
                         DisplayMemberPath="Name"
                         BorderThickness="1" BorderBrush="#E0E0E0" FontSize="16" Padding="5">
                </ListBox>
            </Grid>
        </Border>

        <!-- [Row 1, Col 1] 우측 상단: 실시간 주문 로그 패널 -->
        <Border Grid.Row="1" Grid.Column="1"
                Margin="0, 15, 15, 7.5" Background="White" CornerRadius="8" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="📝 실시간 결제 로그" 
                           FontSize="16" FontWeight="SemiBold" Margin="0, 0, 0, 10" Foreground="#34495E"/>

                <!-- 주문 로그 리스트 -->
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding OrderLogs}"
                         BorderThickness="0" Background="#FAFAFA" FontSize="14" Padding="10"/>
            </Grid>
        </Border>


        <!-- [Row 2, Col 1] 우측 하단: 총 결제 금액 및 버튼 제어 패널 -->
        <Border Grid.Row="2" Grid.Column="1"
                Margin="0, 7.5, 15, 15" Background="White" CornerRadius="8"
                Padding="15">
            <StackPanel>
                <!-- 총 결제 금액 표시 영역 -->
                <DockPanel Margin="0,0,0,15">
                    <TextBlock Text="총 결제 금액:" FontSize="18" FontWeight="Bold" Foreground="#7F8C8D" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:C0}원}" 
                               FontSize="26" FontWeight="Heavy" Foreground="#E74C3C" 
                               HorizontalAlignment="Right" TextAlignment="Right"/>
                </DockPanel>

                <!-- 제어 버튼 2개 배치 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 임시 테스트: 첫 번째 상품(아메리카노)을 주문에 추가하는 버튼 -->
                    <Button Grid.Column="0" Content="☕ 1번 상품 주문 테스트" 
                            Command="{Binding AddOrderCommand}"
                            CommandParameter="{Binding Products[0]}"
                            Height="45" Background="#27AE60" Foreground="White" FontSize="14" FontWeight="Bold" BorderThickness="0"/>

                    <!-- 주문 초기화 버튼 -->
                    <Button Grid.Column="2" Content="🗑️ 주문 내역 초기화" 
                            Command="{Binding ClearOrderCommand}"
                            Height="45" Background="#E74C3C" Foreground="White" FontSize="14" FontWeight="Bold" BorderThickness="0"/>

                </Grid>
            </StackPanel>
            
        </Border>
    </Grid>
</Window>
