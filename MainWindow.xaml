<Window x:Class="MiniPos.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"                
        Title="{Binding Title}" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#F5F6F8">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!--[Row 0, Col 0~1] 상단 헤더 바 -->
        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                Background="#2C3E50" Padding="20,0">
            <TextBlock Text="{Binding Title}"
                       Foreground="White" FontSize="20" FontWeight="Bold"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- [Row 1~2, Col 0] 좌측: 상품 목록 패널 -->
        <Border Grid.Row="1" Grid.RowSpan="2" Grid.Column="0"
                Margin="15" Background="White" CornerRadius="8"
                Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <!-- 영역 타이틀 -->
                <TextBlock Grid.Row="0" Text="📦 상품 선택 (클릭하여 주문)"
                           FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="#34495E"/>
                <!-- 상품 목록을 출력하는 ListBox -->
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Products}"
                         SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
                         HorizontalAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         BorderThickness="0" Background="Transparent" Padding="5">

                    <!-- ★ 1. 그리드 형태의 레이아웃 배치 (2열 바둑판 배열) -->
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2" VerticalAlignment="Top"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>

                    <!-- ★ 2. 컨테이너 스타일 (선택/호버 시 배경 및 테두리 효과 제거/수정) -->
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Margin" Value="6"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>                        
                    </ListBox.ItemContainerStyle>

                    <!-- ★ 3. 데이터 템플릿 (개별 상품 카드 UI 정의) -->
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <!-- 상품 카드 외벽 (Border) -->
                            <Border x:Name="CardBorder"
                                    Background="White"
                                    BorderBrush="#E2E8F0"
                                    BorderThickness="1.5"
                                    CornerRadius="12"
                                    Padding="14"
                                    Cursor="Hand">
                                <!-- 그림자 효과 추가 -->
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="8" ShadowDepth="2"/>
                                </Border.Effect>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>  <!--카테고리-->
                                        <RowDefinition Height="Auto"/>  <!--상품명-->
                                        <RowDefinition Height="Auto"/>  <!--가격-->
                                    </Grid.RowDefinitions>

                                    <!-- ① 카테고리 뱃지 (좌측 상단) -->
                                    <!-- 카테고리에 따라 색상이 변하는 트리거는 아래 DataTemplate.Triggers에서 구현 -->
                                    <Border x:Name="BadgeBorder"
                                        Grid.Row="0" 
                                        Background="#EBF4FF" 
                                        CornerRadius="6" 
                                        Padding="8,3" 
                                        HorizontalAlignment="Left" 
                                        Margin="0,0,0,10">
                                        <TextBlock x:Name="BadgeText"
                                           Text="{Binding Category}" 
                                           FontSize="11" 
                                           FontWeight="Bold" 
                                           Foreground="#3182CE"/>   
                                    </Border>

                                    <!-- ② 상품명 바인딩 -->
                                    <TextBlock Grid.Row="1" 
                                               Text="{Binding Name}"
                                               FontSize="16"
                                               FontWeight="Bold" 
                                               Foreground="#2D3748" 
                                               Margin="0,0,0,8"
                                               TextTrimming="CharacterEllipsis"/>

                                    <!-- ③ 단가 바인딩 (통화 포맷팅 적용) -->
                                    <TextBlock Grid.Row="2" 
                                               Text="{Binding Price, StringFormat={}{0:N0}원}" 
                                               FontSize="18" 
                                               FontWeight="Heavy" 
                                               Foreground="#E53E3E" 
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>
                            <!-- ★ 4. 데이터 및 마우스 상태에 따른 동적 속성 변경 (Triggers) -->
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Category}" Value="Dessert">
                                    <Setter TargetName="BadgeBorder" Property="Background" Value="#FFF5F5"/>
                                    <Setter TargetName="BadgeText" Property="Foreground" Value="#E53E3E"/>
                                </DataTrigger>
                                <!-- 데이터의 Category 값이 "Coffee"면 뱃지를 브라운빛으로 변경 -->
                                <DataTrigger Binding="{Binding Category}" Value="Coffee">
                                    <Setter TargetName="BadgeBorder" Property="Background" Value="#FEFCBF"/>
                                    <Setter TargetName="BadgeText" Property="Foreground" Value="#744210"/>
                                </DataTrigger>

                                <!-- 마우스가 카드 위에 올라갔을 때 (Hover) 테두리와 색상 변경 -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="CardBorder" Property="BorderBrush" Value="#3182CE"/>
                                    <Setter TargetName="CardBorder" Property="Background" Value="#F7FAFC"/>
                                </Trigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>

                </ListBox>
            </Grid>
        </Border>

        <!-- [Row 1, Col 1] 우측 상단: 실시간 주문 로그 패널 -->
        <Border Grid.Row="1" Grid.Column="1"
                Margin="0, 15, 15, 7.5" Background="White" CornerRadius="8" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="📝 실시간 결제 로그" 
                           FontSize="16" FontWeight="SemiBold" Margin="0, 0, 0, 10" Foreground="#34495E"/>

                <!-- 주문 로그 리스트 -->
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding OrderLogs}"
                         BorderThickness="0" Background="#FAFAFA" FontSize="14" Padding="10"/>
            </Grid>
        </Border>


        <!-- [Row 2, Col 1] 우측 하단: 총 결제 금액 및 버튼 제어 패널 -->
        <Border Grid.Row="2" Grid.Column="1"
                Margin="0, 7.5, 15, 15" Background="White" CornerRadius="8"
                Padding="15">
            <StackPanel>
                <!-- 총 결제 금액 표시 영역 -->
                <DockPanel Margin="0,0,0,15">
                    <TextBlock Text="총 결제 금액:" FontSize="18" FontWeight="Bold" Foreground="#7F8C8D" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:C0}원}" 
                               FontSize="26" FontWeight="Heavy" Foreground="#E74C3C" 
                               HorizontalAlignment="Right" TextAlignment="Right"/>
                </DockPanel>

                <!-- 제어 버튼 2개 배치 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 임시 테스트: 첫 번째 상품(아메리카노)을 주문에 추가하는 버튼 -->
                    <Button Grid.Column="0" Content="☕ 1번 상품 주문 테스트" 
                            Command="{Binding AddOrderCommand}"
                            CommandParameter="{Binding Products[0]}"
                            Height="45" Background="#27AE60" Foreground="White" FontSize="14" FontWeight="Bold" BorderThickness="0"/>

                    <!-- 주문 초기화 버튼 -->
                    <Button Grid.Column="2" Content="🗑️ 주문 내역 초기화" 
                            Command="{Binding ClearOrderCommand}"
                            Height="45" Background="#E74C3C" Foreground="White" FontSize="14" FontWeight="Bold" BorderThickness="0"/>

                </Grid>
            </StackPanel>
            
        </Border>
    </Grid>
</Window>
